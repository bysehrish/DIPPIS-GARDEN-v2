rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['items', 'total', 'status', 'createdAt', 'customerName', 'customerAddress', 'customerPhone', 'paymentMethod']) &&
             data.keys().size() >= 8 &&
             data.items is list &&
             data.total is number &&
             data.status is string &&
             data.status in ['pending', 'dispatched', 'completed', 'cancelled'] &&
             data.customerName is string &&
             data.customerAddress is string &&
             data.customerPhone is string &&
             data.paymentMethod == 'cash_on_delivery' &&
             data.createdAt == request.time;
    }

    match /orders/{orderId} {
      // Allow creation of orders (no auth required for now, or you can restrict if needed)
      // Allow reading and updating orders for the admin dashboard
      allow create: if isValidOrder(request.resource.data);
      allow read, update: if true; // In a real app, protect this with auth (e.g. if request.auth != null)
    }
  }
}
